{
  "name": "gomp",
  "private": true,
  "version": "3.13.0",
  "description": "GOMP: Go Meal Planner - A web-based recipe book",
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "stencil build",
    "clear": "rm -fr ./node_modules",
    "clean": "rm -fr ./www && rm -fr src/generated",
    "codegen": "rm -rf src/generated && openapi-generator-cli generate",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil-test",
    "test.watch": "stencil-test --watch",
    "cover": "stencil-test --coverage",
    "generate": "stencil generate"
  },
  "devDependencies": {
    "@ionic/core": "^8.5.7",
    "@openapitools/openapi-generator-cli": "^2.7.0",
    "@stencil/core": "^4.9.0",
    "@stencil/store": "^2.0.12",
    "@stencil/vitest": "^1.10.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dompurify": "^3.2.6",
    "jsdom": "^29.0.1",
    "jwt-decode": "^4.0.0",
    "vitest": "^4.1.2",
    "vitest-fetch-mock": "^0.4.5"
  }
}
